# ===== Discord =====
# Token bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=your_bot_token_here

# Application / Client ID (Developer Portal > General Information)
CLIENT_ID=your_client_id_here

# ID server SMP — untuk registrasi slash command instan saat development
# (cara dapat: aktifkan Developer Mode di Discord, klik kanan server > Copy Server ID)
GUILD_ID=your_guild_id_here

# Channel tempat bot mem-post listing marketplace
# (klik kanan channel > Copy Channel ID)
MARKETPLACE_CHANNEL_ID=your_channel_id_here

# ===== Database =====
# SQLite lokal — cukup file, tidak perlu server (XAMPP/Laragon/dll).
# File data.db otomatis dibuat saat `npm run db:push`. JANGAN di-commit.
DATABASE_URL=file:./data.db

# ===== IPC Bot <-> Mod (dipakai mulai Fase C) =====
# Port REST + WebSocket lokal untuk mod Fabric.
API_PORT=8765
# Shared-secret untuk autentikasi mod <-> bot. Isi string acak panjang.
API_SECRET=ganti_dengan_string_acak
