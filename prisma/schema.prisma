// Skema database Marketplace Bot
// Lihat CLAUDE.md untuk penjelasan data model & keputusan desain.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Enums =====

enum ListingType {
  SELL // user menjual barang
  BUY  // user mencari/ingin membeli barang
}

enum ListingStatus {
  ACTIVE    // tampil di marketplace, menerima offer/buy
  RESERVED  // terkunci untuk 1 pembeli setelah Accept offer (24 jam) — Fase E
  PENDING   // sudah ada deal, menunggu trade in-game selesai
  COMPLETED // trade selesai
  CANCELLED // dibatalkan creator
  EXPIRED   // kadaluarsa (Fase 2)
}

enum OfferStatus {
  
  PENDING   // menunggu respons creator listing
  ACCEPTED  // diterima → jadi transaksi
  REJECTED  // ditolak (manual atau otomatis saat offer lain diterima)
  WITHDRAWN // ditarik kembali oleh pembuat offer (Fase 2)
}

enum TransactionStatus {
  AGREED    // deal tercapai, menunggu trade in-game
  COMPLETED // trade in-game selesai
}

// ===== Models =====

// Peta akun Discord <-> Minecraft. Satu pemain = satu baris (relasi 1:1).
// Dibuat saat pemain menukar kode linking (lihat LinkCode).
model PlayerLink {
  id            Int      @id @default(autoincrement())
  discordId     String   @unique // Discord user ID
  minecraftUuid String   @unique // UUID Minecraft (sumber kebenaran identitas in-game)
  minecraftName String // cache nama, untuk tampilan (bisa berubah, bukan kunci)
  linkedAt      DateTime @default(now())
}

// Kode sementara untuk proses linking. Dibuat oleh /link di Discord,
// ditukar dari in-game. Sekali pakai & kedaluwarsa (lihat linkService).
model LinkCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique // kode pendek alfanumerik, mis. "A3F9K2"
  discordId String   @unique // satu user hanya punya satu kode aktif
  expiresAt DateTime // setelah ini, kode tidak berlaku
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Listing {
  id            Int           @id @default(autoincrement())
  creatorId     String // Discord user ID
  type          ListingType
  // ----- Barang yang dijual/dicari (terstruktur) -----
  itemKey       String // id kanonik MC, mis. "minecraft:elytra"
  itemLabel     String // teks tampilan, mis. "Elytra [Unbreaking III]"
  quantity      Int           @default(1)
  // ----- Harga = item pembayaran + jumlah -----
  priceItemKey  String // id item pembayaran, mis. "minecraft:diamond"
  priceQuantity Int // jumlah item pembayaran
  description   String?
  status        ListingStatus @default(ACTIVE)
  messageId     String? // ID embed di channel marketplace (utk update tampilan)
  // ----- Field escrow & reservasi (dipakai mulai Fase E; nullable dulu) -----
  escrowRef     String? // ID slot escrow di mod (SELL yg barangnya sudah disetor)
  reservedFor   String? // Discord user ID pembeli, saat RESERVED
  reservedUntil DateTime? // batas waktu reservasi (+24 jam)
  createdAt     DateTime      @default(now())
  expiresAt     DateTime? // opsional (Fase 2)

  offers       Offer[]
  transactions Transaction[]

  @@index([status])
  @@index([creatorId])
  @@index([itemKey])
}

model Offer {
  id            Int         @id @default(autoincrement())
  listingId     Int
  buyerId       String // Discord user ID pembuat offer
  // ----- Usulan harga = item pembayaran + jumlah -----
  priceItemKey  String // usulan item bayar, mis. "minecraft:diamond"
  priceQuantity Int // usulan jumlah
  message       String?
  status        OfferStatus @default(PENDING)
  createdAt     DateTime    @default(now())

  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

model Transaction {
  id            Int               @id @default(autoincrement())
  listingId     Int
  offerId       Int? // NULL kalau Buy Now (tanpa offer)
  sellerId      String // pihak yang melepas barang
  buyerId       String // pihak yang menerima barang
  // ----- Pembayaran final = item + jumlah -----
  finalItemKey  String // id item pembayaran final
  finalQuantity Int // jumlah pembayaran final
  status        TransactionStatus @default(AGREED)
  createdAt     DateTime          @default(now())
  completedAt   DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  offer   Offer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([sellerId])
  @@index([buyerId])
}
